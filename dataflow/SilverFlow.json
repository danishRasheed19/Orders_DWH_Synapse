{
	"name": "SilverFlow",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Parquet2",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "Silver_DS",
						"type": "DatasetReference"
					},
					"name": "SilverSink"
				}
			],
			"transformations": [
				{
					"name": "AddDomain"
				},
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          OrderID as string,",
				"          OrderDate as string,",
				"          CustomerID as string,",
				"          CustomerName as string,",
				"          CustomerEmail as string,",
				"          ProductID as string,",
				"          ProductName as string,",
				"          ProductCategory as string,",
				"          RegionID as string,",
				"          RegionName as string,",
				"          Country as string,",
				"          Quantity as string,",
				"          UnitPrice as string,",
				"          TotalAmount as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet') ~> source1",
				"source1 derive(Domain = split(CustomerEmail,'@')[2]) ~> AddDomain",
				"AddDomain derive(First_Name = split(CustomerName, ' ')[1]) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SilverSink"
			]
		}
	}
}